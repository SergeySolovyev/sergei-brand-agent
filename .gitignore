# Secrets — never commit
.env
.env.*
!.env.template
*.key
*.pem
secrets/
credentials/
.password-store/

# Hermes state
.hermes/
state.sqlite
state.sqlite-journal
state.sqlite-wal
state.sqlite-shm

# Browser profiles (cookies, sessions)
browser-profile/
playwright-data/
.cache/
.chromium/

# Traces & runtime data
data/traces/*
!data/traces/.gitkeep
data/drafts/*
!data/drafts/.gitkeep
data/pulse/*
!data/pulse/.gitkeep
data/plans/*
!data/plans/.gitkeep

# Knowledge base ingested files (generated)
knowledge_base/identity.json
knowledge_base/preprints.json
knowledge_base/brand_voice_corpus.md
# (glossary.md and promotion_playbook.md ARE committed — manual content)

