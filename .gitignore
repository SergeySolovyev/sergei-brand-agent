*.py[cod]
*$py.class
*.so
.venv/
venv/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.coverage
htmlcov/

# Node
node_modules/
npm-debug.log
yarn-error.log
.pnpm-debug.log

# Docker
.dockerignore
docker-compose.override.yml

# IDE
.vscode/
.idea/
*.swp
*.swo
