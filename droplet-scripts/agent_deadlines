        "link": "https://7universum.com/",
    },
]


def severity_from_days(days):
    if days < 3:
        return "critical"
    if days <= 7:
        return "high"
    if days <= 14:
        return "medium"
    return "low"


def main():
    state_db = Path("/root/.openclaw/agent_state.sqlite")
    db = sqlite3.connect(state_db)
    db.execute(
        "CREATE TABLE IF NOT EXISTS deadline_emit_log "
        "(deadline_id TEXT, severity TEXT, emitted_at TEXT, PRIMARY KEY (deadline_id, severity))"
    )

    # Allow user override
    user_file = Path("/opt/brand-agent/knowledge_base/deadlines.json")
    deadlines = DEFAULT_DEADLINES
    if user_file.exists():
        try:
            deadlines = json.loads(user_file.read_text())
        except Exception:
            pass

    today = date.today()
    for d in deadlines:
        try:
            dl_date = date.fromisoformat(d["deadline"])
        except Exception:
            continue
        days = (dl_date - today).days
        if days < 0:
            continue  # past

        sev = severity_from_days(days)
        already_emitted = db.execute(
            "SELECT 1 FROM deadline_emit_log WHERE deadline_id=? AND severity=?",
            (d["id"], sev),
        ).fetchone()
        if already_emitted and sev not in ("critical",):
            # critical re-emit every day until acknowledged or past
            continue

        actions_md = "\n".join(f"- {a}" for a in d.get("actions_needed", []))
        body = (
            f"**{d['title']}**\n\n"
            f"Deadline: {d['deadline']} ({days} day{'s' if days != 1 else ''} away)\n"
            f"Category: {d.get('category', '?')}\n"
            f"Link: {d.get('link', '')}\n\n"
            f"**Actions still needed:**\n{actions_md}\n"
        )
        subprocess.run(
            [
                "/usr/local/bin/emit_event",
                sev,
                "deadline_approaching",
                f"{d['title']} — {days}d",
                body,
            ],
            check=False,
        )
        db.execute(
            "INSERT OR REPLACE INTO deadline_emit_log VALUES (?, ?, ?)",
            (d["id"], sev, datetime.now(timezone.utc).isoformat()),
        )
        db.commit()

    print(f"deadlines tick complete at {datetime.now(timezone.utc).isoformat()}")


if __name__ == "__main__":
    main()
