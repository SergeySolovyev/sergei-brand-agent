#!/usr/bin/env python3
"""Deadline tracker: emit critical alerts when known deadlines approach.

Runs daily at 09:00 UTC. Reads /opt/brand-agent/knowledge_base/deadlines.json
(or built-in defaults) and emits severity based on days remaining:
  > 14 days  → low (rolled into daily digest only)
  7-14 days  → medium (digest only)
  3-7 days   → high (Telegram push + git)
  < 3 days   → critical (push + retry until /ack)

Idempotent — same deadline only emits once per severity transition (tracked
in agent_state.sqlite).
"""
import json, sqlite3, subprocess
from pathlib import Path
from datetime import datetime, timezone, date

# Sergei's actual deadlines — hardcoded as ground truth for now.
# If knowledge_base/deadlines.json exists, override from there.
DEFAULT_DEADLINES = [
    {
