#!/opt/brand-agent/venv/bin/python3
"""blog_generator — Composer-driven blog post draft for sergeisolovev.com.

Usage:
  blog_generator <preprint_slug> [--lang en|ru]

Pipeline:
  1. Read preprint metadata from knowledge_base/preprints.json (or hardcoded)
  2. Composer (claude-cli, Sonnet) drafts a 1200-1500 word blog post:
     - Hooks first paragraph with concrete problem
     - Plain-language summary of method
     - "Why it matters" practical implications
     - SEO meta description + 5-7 tags
     - Frontmatter compatible with sergeisolovev.com static site format
  3. Critic (claude-cli, Sonnet) does one pass — catches factual errors,
     brand-tone drift, over-promised claims
  4. If Critic PASS → save to /opt/reports/drafts/YYYY-MM-DD-<slug>.md +
     git commit + TG notification with [📝 Edit] [✅ Publish via PR] [❌ Reject]
  5. If Critic REVISE → 1 revision round, then auto-PASS or escalate

Cron: Mon 10:00 UTC (one new draft per week). For ad-hoc, run manually.
"""
import json
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

DRAFTS_DIR = Path("/opt/reports/drafts")
SOUL_PATH = Path("/opt/brand-agent/SOUL.md")

# Hardcoded preprint catalog (mirror of figshare 5)
PREPRINTS = {
    "honest-rag-solidity": {
        "title": "Honest-RAG-Solidity: Retrieval-Augmented Vulnerability Detection in Smart Contracts",
        "doi": "10.6084/m9.figshare.32141182",
