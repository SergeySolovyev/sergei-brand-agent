# =============================================================================
# sergei-brand-agent — environment variables template
#
# Copy to .env and fill in your real values. NEVER commit .env (it's gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# LLM providers (at least one required)
# -----------------------------------------------------------------------------

# Anthropic — primary for Composer + Critic (highest quality drafts + reviews)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXX
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5

# OpenRouter — fallback + free models for Strategist
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXX
OPENROUTER_STRATEGIST_MODEL=nousresearch/hermes-3-llama-3.1-405b
OPENROUTER_DRAFTING_MODEL=anthropic/claude-sonnet-4-5

# -----------------------------------------------------------------------------
# Telegram (required — primary control surface)
# -----------------------------------------------------------------------------

# From @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# From @userinfobot (your own user ID, comma-separated if multiple)
TELEGRAM_ALLOWED_USERS=123456789

# Chat ID to send scheduled digests (use bot to /getchatid first time)
TELEGRAM_HOME_CHANNEL=

# Use webhooks (recommended on VPS) or polling (default; works behind NAT)
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Browser-Use (universal channel access)
# -----------------------------------------------------------------------------

# If using Browser-Use Cloud (managed Chromium)
BROWSER_USE_API_KEY=

# Local headless Chromium otherwise
BROWSER_USE_HEADLESS=true
BROWSER_USE_PROFILE_DIR=/home/agent/.config/chromium-profile
BROWSER_USE_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36

# -----------------------------------------------------------------------------
# Anthropic Computer Use (Phase 2 — desktop fallback)
# -----------------------------------------------------------------------------

COMPUTER_USE_ENABLED=false
COMPUTER_USE_DISPLAY_WIDTH=1280
COMPUTER_USE_DISPLAY_HEIGHT=800
COMPUTER_USE_VNC_PASSWORD=

# -----------------------------------------------------------------------------
# RentAHuman MCP (Phase 2 — human-in-loop escalation)
# -----------------------------------------------------------------------------

RAH_ENABLED=false
RAH_MCP_URL=https://rentahuman.ai/mcp
RAH_API_KEY=
RAH_DEFAULT_BUDGET_USD=15
RAH_TIMEOUT_MINUTES=20

# -----------------------------------------------------------------------------
# GitHub (commits to sergeisolovev.com, repo ops)
# -----------------------------------------------------------------------------

# Personal Access Token (Fine-grained, scoped to SergeySolovyev/sergeisolovev.com)
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_USERNAME=SergeySolovyev
GITHUB_EMAIL=sesesolovev@edu.hse.ru
GITHUB_BLOG_REPO=SergeySolovyev/sergeisolovev.com

# -----------------------------------------------------------------------------
# OpenAlex (free, no auth — for monitoring citations)
# -----------------------------------------------------------------------------

OPENALEX_AUTHOR_ID=A5127404993
OPENALEX_POLITE_EMAIL=sesesolovev@edu.hse.ru

# -----------------------------------------------------------------------------
# Search Console (Phase 2 — indexing monitor)
# -----------------------------------------------------------------------------

GOOGLE_SEARCH_CONSOLE_OAUTH_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_OAUTH_CLIENT_SECRET=
GOOGLE_SEARCH_CONSOLE_REFRESH_TOKEN=
GOOGLE_SEARCH_CONSOLE_PROPERTY=https://sergeisolovev.com/

# -----------------------------------------------------------------------------
# figshare (monitoring downloads)
# -----------------------------------------------------------------------------

FIGSHARE_AUTHOR_ID=23264342
# Personal token only if you need write ops; for read-only monitoring, leave blank
FIGSHARE_TOKEN=

# -----------------------------------------------------------------------------
# LinkedIn / X — browser cookies persist in browser profile; no API keys needed
# -----------------------------------------------------------------------------

# (LinkedIn / X credentials handled via Browser-Use session cookies)

# -----------------------------------------------------------------------------
# Operations
# -----------------------------------------------------------------------------

TZ=Europe/Moscow
LOG_LEVEL=INFO
DAILY_COST_CAP_USD=5
WEEKLY_COST_CAP_USD=25
MONTHLY_COST_CAP_USD=80

# Drafts-only mode: if true, never publishes; all output as drafts in data/drafts/
DRAFTS_ONLY_MODE=false

# Telegram-only mode: only publishes to Telegram (Tier 1 only); useful during burn-in
TELEGRAM_ONLY_MODE=false

# Kill switch: if true, agent reads queue but takes no actions
EMERGENCY_PAUSE=false

# -----------------------------------------------------------------------------
# Sandbox / Security
# -----------------------------------------------------------------------------

SANDBOX_NETWORK_WHITELIST=sergeisolovev.com,github.com,api.github.com,raw.githubusercontent.com,linkedin.com,www.linkedin.com,twitter.com,x.com,openalex.org,api.openalex.org,scholar.google.com,figshare.com,api.figshare.com,rentahuman.ai,api.indexnow.org,openrouter.ai,api.anthropic.com,telegram.org,api.telegram.org,web.archive.org

# -----------------------------------------------------------------------------
# Vault (optional, recommended for production)
# -----------------------------------------------------------------------------

VAULT_ENABLED=false
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/sergei-brand-agent

# OR 1Password Connect
OP_CONNECT_HOST=
OP_CONNECT_TOKEN=
OP_VAULT_ID=
